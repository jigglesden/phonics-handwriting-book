{{ 'mphb-custom.css' | asset_url | stylesheet_tag }}

<section class="mphb-section mphb-testimonials" data-section-name="mphb-testimonials">
  <div class="mphb-page-width">
    <div class="mphb-section-header">
      <p class="mphb-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="mphb-heading mphb-heading--lg">{{ section.settings.heading }}</h2>
    </div>

    <div class="mphb-grid mphb-grid--3">
      {%- for block in section.blocks -%}
        <figure class="mphb-card mphb-testimonial" {{ block.shopify_attributes }}>
          <div class="mphb-stars" aria-label="5 out of 5 stars">*****</div>
          <blockquote>{{ block.settings.quote }}</blockquote>
          <cite>{{ block.settings.citation }}</cite>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MPHB testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What teachers are saying"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved by teachers who want explicit, effective handwriting practice"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This is the first handwriting resource we have found that genuinely aligns with our phonics sequence. It has made handwriting lessons feel structured and purposeful."
        },
        {
          "type": "text",
          "id": "citation",
          "label": "Citation",
          "default": "Sarah M., Literacy Leader"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MPHB testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "This is the first handwriting resource we have found that genuinely aligns with our phonics sequence. It has made handwriting lessons feel structured and purposeful.",
            "citation": "Sarah M., Literacy Leader"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "The decodable words are a game changer. My students are reading what they write, and handwriting time finally reinforces our literacy block.",
            "citation": "James T., Year 1 Teacher"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Beautifully designed, easy to use and so effective. A must-have for early classrooms using structured literacy.",
            "citation": "Megan R., Assistant Principal"
          }
        }
      ]
    }
  ]
}
{% endschema %}
