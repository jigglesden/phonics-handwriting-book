{{ 'mphb-custom.css' | asset_url | stylesheet_tag }}

<section class="mphb-section mphb-books" data-section-name="mphb-book-finder">
  <div class="mphb-page-width">
    <div class="mphb-section-header">
      <p class="mphb-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="mphb-heading mphb-heading--lg">{{ section.settings.heading }}</h2>
      <div class="mphb-subheading">{{ section.settings.subheading }}</div>
    </div>

    <div class="mphb-grid mphb-books__grid">
      {%- for block in section.blocks -%}
        <article class="mphb-card mphb-book-card" style="--accent: {{ block.settings.accent }};" {{ block.shopify_attributes }}>
          <img src="{{ block.settings.image | asset_url }}" alt="{{ block.settings.title | escape }}" width="412" height="578" loading="lazy">
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.description }}</p>
          <div class="mphb-book-card__meta">
            <span class="mphb-pill">{{ block.settings.level }}</span>
            <span class="mphb-pill">{{ block.settings.font }}</span>
          </div>
          {%- assign card_link = block.settings.link | default: '/collections/all' -%}
          <a class="mphb-button mphb-button--secondary" href="{{ card_link }}">{{ block.settings.button_label }}</a>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MPHB book finder",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Choose the right book"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A structured progression to support every learner"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Start with foundation formation, then move into digraphs, vowel teams and extended code as students progress.</p>"
    }
  ],
  "blocks": [
    {
      "type": "book",
      "name": "Book",
      "settings": [
        {
          "type": "text",
          "id": "image",
          "label": "Theme asset filename",
          "default": "mphb-book-a-nsw.png"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Book A"
        },
        {
          "type": "text",
          "id": "level",
          "label": "Level",
          "default": "Foundation"
        },
        {
          "type": "text",
          "id": "font",
          "label": "Font",
          "default": "NSW and Vic"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "For students learning early sound-letter correspondences and core letter formation."
        },
        {
          "type": "color",
          "id": "accent",
          "label": "Accent",
          "default": "#8ebfae"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Explore book"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MPHB book finder",
      "blocks": [
        {
          "type": "book",
          "settings": {
            "image": "mphb-book-a-nsw.png",
            "title": "Book A",
            "level": "Foundation / Prep",
            "font": "NSW, Vic, Tas",
            "description": "For students learning early sound-letter correspondences, CVC words and foundational handwriting routines.",
            "accent": "#8ebfae",
            "button_label": "Explore Book A"
          }
        },
        {
          "type": "book",
          "settings": {
            "image": "mphb-book-b-nsw.png",
            "title": "Book B",
            "level": "Grade 1",
            "font": "NSW, Vic, Tas",
            "description": "For students moving into digraphs, extended code, sentence practice and stronger handwriting automaticity.",
            "accent": "#7db5d8",
            "button_label": "Explore Book B"
          }
        },
        {
          "type": "book",
          "settings": {
            "image": "mphb-book-b-vic.jpg",
            "title": "Book C",
            "level": "Grade 2",
            "font": "Tas",
            "description": "For continued fluency work across vowel teams, suffixes, affixes and lower-frequency spelling patterns.",
            "accent": "#a997d0",
            "button_label": "Explore Book C"
          }
        }
      ]
    }
  ]
}
{% endschema %}
