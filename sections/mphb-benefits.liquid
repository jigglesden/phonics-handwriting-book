{{ 'mphb-custom.css' | asset_url | stylesheet_tag }}

<section class="mphb-section mphb-benefits" data-section-name="mphb-benefits">
  <div class="mphb-page-width">
    <div class="mphb-section-header">
      <p class="mphb-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="mphb-heading mphb-heading--lg">{{ section.settings.heading }}</h2>
    </div>

    <div class="mphb-grid mphb-grid--4">
      {%- for block in section.blocks -%}
        <div class="mphb-card mphb-benefit-card" {{ block.shopify_attributes }}>
          <span class="mphb-icon-bubble" aria-hidden="true">{{ forloop.index }}</span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MPHB teacher benefits",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Why teachers choose My Phonics Handwriting Book"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A simple daily routine with literacy impact"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Reinforces phonics instruction"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Every activity supports the sound-spelling knowledge students are learning."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MPHB teacher benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "heading": "Reinforces phonics instruction",
            "text": "Every activity supports the sound-spelling knowledge students are learning."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "heading": "Reduces teacher preparation",
            "text": "Open the book and teach from a consistent daily routine."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "heading": "Structured progression",
            "text": "Skills build logically from single sounds to extended code."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "heading": "Classroom tested",
            "text": "Created, refined and used by educators in real classrooms."
          }
        }
      ]
    }
  ]
}
{% endschema %}
