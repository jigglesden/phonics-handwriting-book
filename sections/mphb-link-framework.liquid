{{ 'mphb-custom.css' | asset_url | stylesheet_tag }}

<section class="mphb-section mphb-link" data-section-name="mphb-link-framework">
  <div class="mphb-page-width">
    <div class="mphb-section-header">
      <p class="mphb-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="mphb-heading mphb-heading--lg">{{ section.settings.heading }}</h2>
      <div class="mphb-subheading">{{ section.settings.subheading }}</div>
    </div>

    <div class="mphb-grid mphb-link__cards">
      {%- for block in section.blocks -%}
        <div class="mphb-card mphb-link__card" {{ block.shopify_attributes }}>
          <span class="mphb-icon-bubble" aria-hidden="true">{{ forloop.index }}</span>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MPHB learning link",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The missing link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Missing Link Between Phonics and Handwriting"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>When students write words containing sounds they already know, handwriting practice becomes another opportunity to strengthen reading and spelling.</p>"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Decodable practice"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Students only practise words aligned with taught phonics concepts."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MPHB learning link",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "heading": "Decodable practice",
            "text": "Students only practise words aligned with taught phonics concepts."
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "Explicit letter formation",
            "text": "Consistent modelling and tracing support accurate formation."
          }
        },
        {
          "type": "step",
          "settings": {
            "heading": "Stronger literacy outcomes",
            "text": "Writing routines reinforce spelling, reading and transcription."
          }
        }
      ]
    }
  ]
}
{% endschema %}
