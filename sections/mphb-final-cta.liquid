{{ 'mphb-custom.css' | asset_url | stylesheet_tag }}

<section class="mphb-section mphb-final-cta" data-section-name="mphb-final-cta">
  <div class="mphb-page-width">
    <div class="mphb-final-cta__wrap">
      <div>
        <p class="mphb-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="mphb-heading mphb-heading--lg">{{ section.settings.heading }}</h2>
        <div class="mphb-subheading">{{ section.settings.subheading }}</div>
        <div class="mphb-button-row">
          {%- assign primary_link = section.settings.primary_link | default: '/collections/all' -%}
          {%- assign secondary_link = section.settings.secondary_link | default: '/pages/downloads' -%}
          <a class="mphb-button" href="{{ primary_link }}">{{ section.settings.primary_label }}</a>
          <a class="mphb-button mphb-button--secondary" href="{{ secondary_link }}">{{ section.settings.secondary_label }}</a>
        </div>
      </div>
      <img class="mphb-final-cta__image" src="{{ 'mphb-book-tubs.png' | asset_url }}" alt="My Phonics Handwriting Book classroom tubs" width="1536" height="1024" loading="lazy">
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MPHB final CTA",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Ready to make handwriting more meaningful?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Give your students handwriting practice that supports literacy development"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Choose the book that matches your year level and handwriting font, or download sample pages first.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "View the books"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Download sample pages"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "MPHB final CTA"
    }
  ]
}
{% endschema %}
