{{ 'mphb-custom.css' | asset_url | stylesheet_tag }}

<section class="mphb-section mphb-proof-strip" data-section-name="mphb-proof-strip">
  <div class="mphb-page-width">
    <div class="mphb-grid mphb-proof-strip__grid">
      {%- for block in section.blocks -%}
        <div class="mphb-proof-item" {{ block.shopify_attributes }}>
          <span class="mphb-icon-bubble" aria-hidden="true">{{ block.settings.icon }}</span>
          <strong>{{ block.settings.heading }}</strong>
          <span>{{ block.settings.text }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MPHB proof strip",
  "blocks": [
    {
      "type": "proof",
      "name": "Proof point",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Designed by teachers"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Created for real classrooms"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MPHB proof strip",
      "blocks": [
        {
          "type": "proof",
          "settings": {
            "icon": "01",
            "heading": "Experienced educators",
            "text": "Created by literacy specialists"
          }
        },
        {
          "type": "proof",
          "settings": {
            "icon": "02",
            "heading": "Classroom tested",
            "text": "Built around daily instruction"
          }
        },
        {
          "type": "proof",
          "settings": {
            "icon": "03",
            "heading": "Phonics aligned",
            "text": "Decodable practice throughout"
          }
        },
        {
          "type": "proof",
          "settings": {
            "icon": "04",
            "heading": "Explicit formation",
            "text": "Clear, repeatable routines"
          }
        },
        {
          "type": "proof",
          "settings": {
            "icon": "05",
            "heading": "Teacher approved",
            "text": "Supports confident lessons"
          }
        }
      ]
    }
  ]
}
{% endschema %}
