{{ 'mphb-custom.css' | asset_url | stylesheet_tag }}

<section class="mphb-section mphb-hero" data-section-name="mphb-hero">
  <div class="mphb-page-width">
    <div class="mphb-hero__grid">
      <div>
        <img
          class="mphb-hero__logo mphb-media"
          src="{{ 'mphb-logo.png' | asset_url }}"
          alt="{{ shop.name | escape }}"
          width="837"
          height="117"
          loading="eager"
        >
        <p class="mphb-eyebrow">{{ section.settings.eyebrow }}</p>
        <h1 class="mphb-heading mphb-heading--xl">{{ section.settings.heading }}</h1>
        <div class="mphb-subheading">{{ section.settings.subheading }}</div>

        <ul class="mphb-hero__bullets" aria-label="Key benefits">
          {%- for block in section.blocks -%}
            <li {{ block.shopify_attributes }}>
              <span aria-hidden="true"></span>
              {{ block.settings.text }}
            </li>
          {%- endfor -%}
        </ul>

        {%- assign primary_link = section.settings.primary_link | default: '/collections/all' -%}
        {%- assign secondary_link = section.settings.secondary_link | default: '/pages/downloads' -%}
        <div class="mphb-button-row">
          <a class="mphb-button" href="{{ primary_link }}">{{ section.settings.primary_label }}</a>
          <a class="mphb-button mphb-button--secondary" href="{{ secondary_link }}">{{ section.settings.secondary_label }}</a>
        </div>

        <div class="mphb-hero__proof" aria-label="Social proof">
          <span class="mphb-pill">Created by educators</span>
          <span class="mphb-pill">Aligned with explicit instruction</span>
          <span class="mphb-pill">10-15 min daily lessons</span>
        </div>
      </div>

      <div class="mphb-hero__visual" aria-label="My Phonics Handwriting Book examples">
        <div class="mphb-book-stack">
          <img
            class="mphb-book-stack__book mphb-book-stack__book--a"
            src="{{ 'mphb-book-a-nsw.png' | asset_url }}"
            alt="My Phonics Handwriting Book A cover"
            width="405"
            height="578"
            loading="eager"
          >
          <img
            class="mphb-book-stack__book mphb-book-stack__book--b"
            src="{{ 'mphb-book-b-nsw.png' | asset_url }}"
            alt="My Phonics Handwriting Book B cover"
            width="412"
            height="578"
            loading="eager"
          >
          <img
            class="mphb-book-stack__book mphb-book-stack__book--c"
            src="{{ 'mphb-book-b-vic.jpg' | asset_url }}"
            alt="My Phonics Handwriting Book B Victorian Font cover"
            width="595"
            height="842"
            loading="eager"
          >
        </div>
        <div class="mphb-hero__student mphb-card">
          <img
            class="mphb-media"
            src="{{ 'mphb-student-writing.png' | asset_url }}"
            alt="Student practising handwriting"
            width="476"
            height="494"
            loading="eager"
          >
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MPHB hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Phonics-aligned handwriting workbooks"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Handwriting Practice That Reinforces Phonics"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Decodable handwriting workbooks designed to strengthen letter formation, reading and spelling through explicit phonics-aligned practice.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "View the books"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Download sample pages"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Aligned with structured literacy approaches"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MPHB hero",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "text": "Aligned with structured literacy approaches"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Uses decodable words students can actually read"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Classroom-tested by Australian educators"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Suitable for Foundation and early primary years"
          }
        }
      ]
    }
  ]
}
{% endschema %}
